# 19888 Platform Environment Variables

# JWT Secret (change this! generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-32-byte-hex-secret-here

# Sepolia RPC URL (for on-chain tx verification)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# LuckyPool contract address on Sepolia (for deposit verification)
LUCKY_POOL_ADDRESS=0x02fda9c22d6f8733bA507Ed1019d67571626e9DA

# Admin password (default: 19888admin — CHANGE IN PRODUCTION)
ADMIN_PASSWORD=19888admin

# Server port
PORT=3088
